    "multicolumn_LmFEyD": {
      "type": "multicolumn",
      "blocks": {
        "column_xYgFRw": {
          "type": "column",
          "settings": {
            "title": "<strong>STEP 1 : GET IN TOUCH</strong>",
            "text": "<p>Just reach out to us and let us know what happened. We may need you to send us a photo of what's happened to the tee. In some rare cases we may ask you to send the tee back to us - we'll provide a postage label for this in this case.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_rtKPzW": {
          "type": "column",
          "settings": {
            "title": "STEP 2  : GET YOUR REPLACEMENT",
            "text": "<p>We'll ship out your complimentary replacement. We just ask that you cover the shipping on the replacement item, that's it!</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": [

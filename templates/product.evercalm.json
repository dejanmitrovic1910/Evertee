    "rich_text_yB7Jea": {
      "type": "rich-text",
      "blocks": {
        "heading_f8BmiA": {
          "type": "heading",
          "settings": {
            "heading": "IS THIS RIGHT FOR MY CHILD?",
            "heading_size": "h1"
          }
        },
        "text_aqrwDb": {
          "type": "text",
          "settings": {
            "text": "<p>Evercalm works best for children who are sensitive to labels, rough fabrics, or clothing that feels different from one day to the next. It’s designed for kids who prefer familiar, comfortable clothes and often want to wear the same t-shirt repeatedly.</p><p>Every child is different, but for many families, this tee removes the most common frustrations around getting dressed.</p>"
          }
        },
        "button_zyy9mV": {

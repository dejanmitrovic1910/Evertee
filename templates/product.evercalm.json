    "multirow_L9f8fz": {
      "type": "multirow",
      "blocks": {
        "row_QeX7gN": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/3813550a-f821-4481-81bb-4449d46fd2bb.jpg",
            "caption": "",
            "heading": "A T-SHIRT THAT FEELS THE SAME EVERY TIME",
            "text": "<p>Getting dressed shouldn’t be unpredictable.</p><p>Evercalm was created to remove the small details that can cause big reactions  labels that scratch, fabrics that feel different from one day to the next, or t-shirts that suddenly stop feeling “right”.</p><p>This tee is soft, tag-free, and designed to stay consistent. The fit doesn’t cling or twist. The fabric doesn’t change after washing. What works one day should still work the next.</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_xV6ryq": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/2187c731-d9b8-47bc-a384-6fccd5c97163.jpg",
            "caption": "",
            "heading": "DESIGNED FOR ROUTINE",
            "text": "<p>Our children often rely on familiar clothing that feels the same each time it’s worn. Changing that can be difficult.</p><p>Evercalm is made to stay consistent and when it’s worn out or outgrown, we replace it with the same t-shirt, so the routine stays intact.</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_FMMeTV": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/b05369b8-f0ae-46d2-a836-61f8cd0cd489.jpg",
            "caption": "",
            "heading": "EVERY DETAIL THOUGHTFULLY DESIGNED",
            "text": "<p>Evercalm is made from soft, organic combed cotton chosen for its smooth, consistent feel. The mid-weight fabric is substantial without being heavy, helping it hold its shape while staying comfortable all day.</p><p>A peel-away neck label removes a common source of irritation, leaving nothing behind to rub or scratch. The classic fit avoids tightness and cling, and reinforced stitching helps the t-shirt keep the same feel and fit over time.</p><p>Every detail is intentional. Nothing extra. Nothing that needs adjusting.</p>",
            "button_label": "",
            "button_link": ""
          }
        }
      },
      "block_order": [
        "row_QeX7gN",
        "row_xV6ryq",
        "row_FMMeTV"
      ],

    "collapsible_content_NNPzfc": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_UqUbNX": {
          "type": "collapsible_row",
          "settings": {
            "heading": "HOW CAN A T-SHIRT LAST A LIFETIME?",
            "icon": "question_mark",
            "row_content": "<p>We don’t cut corners. Evertee is built with premium, sustainable materials designed to outlive your wardrobe. And if it doesn’t? We’ll replace it. Simple as that.</p>",
            "page": ""
          }
        },
        "collapsible_row_fmCMR3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "WHY SHOULD I PAY MORE FOR A T-SHIRT?",
            "icon": "price_tag",
            "row_content": "<p>Because it’s the <em>only</em> t-shirt you’ll ever need. While you’re busy buying dozens of fast-fashion t-shirts every year, Evertee is saving you <strong>money</strong>, time, and the planet. Over a lifetime, it’s a motherflippin' bargain.</p>",
            "page": ""
          }
        },
        "collapsible_row_WQJC9K": {
          "type": "collapsible_row",
          "settings": {
            "heading": "WHAT IF MY T-SHIRT GETS DAMAGED?",
            "icon": "recycle",
            "row_content": "<p>Don’t sweat it. Tear? Hole? Weird stain you don’t want to talk about? Send it back, and we’ll replace it. We’ve got your back for life.</p>",
            "page": ""
          }
        },
        "collapsible_row_67nEph": {

    "multirow_L9f8fz": {
      "type": "multirow",
      "blocks": {
        "row_QeX7gN": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/IMG_4693.png",
            "caption": "",
            "heading": "THE T-SHIRT THAT LASTS A LIFETIME",
            "text": "<p>If anything ever happens to your t-shirt, we’ll replace it, simple. It’s the only t-shirt you’ll ever need — a promise no fast-fashion brand can match.</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_xV6ryq": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/663E0F8C-9551-43A6-A019-D574EEEF11A8.png",
            "caption": "",
            "heading": "THE EASIEST £771 YOU'LL EVER EARN",
            "text": "<p>The average person purchases approximately <strong>80 t-shirts </strong>over their lifetime (1.6 t-shirts/year). At an average cost of £10 per t-shirt, this totals <strong>£800</strong>. Meaning your £29 Evertee could save you up to <strong>£771</strong> over your lifetime. It just makes sense!</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_FMMeTV": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/G5000BlackM459.jpg",
            "caption": "",
            "heading": "SAVE THE EQUIVALENT OF 2,700 BATH TUBS OF WATER",
            "text": "<p>It would take 216,000 liters of water to manufacture the same number of t-shirts as 1 Evertee. Make the change.</p>",
            "button_label": "",
            "button_link": ""
          }
        }
      },

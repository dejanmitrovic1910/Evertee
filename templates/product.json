    "multirow_L9f8fz": {
      "type": "multirow",
      "blocks": {
        "row_QeX7gN": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/IMG_4693.png",
            "caption": "",
            "heading": "THE T-SHIRT THAT LASTS A LIFETIME",
            "text": "<p>If anything ever happens to your t-shirt, we’ll replace it, simple. It’s the only t-shirt you’ll ever need — a promise no fast-fashion brand can match.</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_xV6ryq": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/White_evertee_man_8b7c713c-1fb3-4ccf-b857-6bd3c472887e.png",
            "caption": "",
            "heading": "THE EASIEST MONEY YOU'LL EVER EARN",
            "text": "<p>The average person purchases approximately <strong>80 t-shirts </strong>over their lifetime (1.6 t-shirts/year). Just imagine the money you'll save for more stuff!</p>",
            "button_label": "",
            "button_link": ""
          }
        },
        "row_FMMeTV": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/Evertee_Black.png",
            "caption": "",
            "heading": "SAVE THE EQUIVALENT OF 2,700 BATH TUBS OF WATER",
            "text": "<p>It would take 216,000 liters of water to manufacture the same number of t-shirts as 1 Evertee. Make the change.</p>",
            "button_label": "",
            "button_link": ""
          }
        }
      },
      "block_order": [
        "row_QeX7gN",
        "row_xV6ryq",
        "row_FMMeTV"
      ],

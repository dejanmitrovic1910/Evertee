{% comment %}
  Renders the "Premium Heavy Tee Upgrade" variant option as a card with image, description, cost and yes/no toggle.
  Toggle right = Yes, toggle left = No.
  Accepts: option, block, product_form_id, section_id, step_number, visual_only (optional), variant (optional)
  When visual_only is true, renders display-only copy that syncs with the hidden form inputs in the variant picker.
  variant: when set, which option is checked is derived from this variant (like other option pickers); otherwise uses option.selected_value.
{% endcomment %}
{%- liquid
  assign input_name = option.name | append: '-' | append: option.position
  assign no_value = nil
  assign yes_value = nil
  assign no_id = nil
  assign yes_id = nil
  assign no_url = nil
  assign yes_url = nil
  for value in option.values
    assign v_down = value | downcase
    if v_down == 'no'
      assign no_value = value
      assign no_id = value.id
      assign no_url = value.product_url
    elsif v_down == 'yes'
      assign yes_value = value
      assign yes_id = value.id
      assign yes_url = value.product_url
    endif
  endfor
  if no_value == nil
    assign no_value = option.values[0]
    assign no_id = option.values[0].id
    assign no_url = option.values[0].product_url
  endif
  if yes_value == nil
    assign yes_value = option.values[1] | default: option.values[0]
    assign yes_id = option.values[1].id | default: option.values[0].id
    assign yes_url = option.values[1].product_url | default: option.values[0].product_url
  endif
  assign upgrade_image = block.settings.premium_upgrade_image
  assign upgrade_description = block.settings.premium_upgrade_description | default: 'Upgrade to ultra-durable 220gsm heavyweight fabric for +£2 per tee'
  assign upgrade_cost_raw = block.settings.premium_upgrade_cost | default: '+£2 per tee'
  assign upgrade_cost_parts = upgrade_cost_raw | split: ' per '
  assign upgrade_price = upgrade_cost_parts[0] | strip | default: '+£2'
  assign visual_only = visual_only | default: false
  assign checked_no = false
  assign checked_yes = false
  assign opt_key = 'option' | append: option.position
  if variant != blank
    assign variant_opt_val = variant[opt_key] | downcase | strip
    assign no_val_down = no_value | downcase | strip
    assign yes_val_down = yes_value | downcase | strip
    if variant_opt_val == yes_val_down
      assign checked_yes = true
    else
      assign checked_no = true
    endif
  elsif option.selected_value == yes_value
    assign checked_yes = true
  else
    assign checked_no = true
  endif
  assign id_suffix = ''
  assign visual_name = ''
  if visual_only
    assign id_suffix = '-visual'
    assign visual_name = 'premium-upgrade-visual-' | append: section_id
  endif
-%}
<div class="variant-picker-step__premium-upgrade product-form__input product-form__input--premium-upgrade{% if visual_only %} premium-upgrade-visual{% endif %}" {% if visual_only %}data-premium-upgrade-visual data-section-id="{{ section_id }}" data-option-position="{{ option.position }}"{% endif %}>
  <div class="premium-upgrade-card">
    {%- if upgrade_image != blank -%}
      <div class="premium-upgrade-card__icon">
        <img
          src="{{ upgrade_image | image_url: width: 80 }}"
          alt=""
          width="40"
          height="40"
          loading="lazy"
        >
      </div>
    {%- endif -%}
    <div class="premium-upgrade-card__content">
      <div class="premium-upgrade-card__title">{{ option.name }}</div>
      {%- if upgrade_description != blank -%}
        <p class="premium-upgrade-card__description">{{ upgrade_description }}</p>
      {%- endif -%}
    </div>
    <fieldset class="js product-form__input premium-upgrade-card__toggle-wrap" aria-label="{{ option.name }}">
      <span class="premium-upgrade-toggle" data-premium-upgrade-toggle>
        {%- comment -%} No first (toggle left), then Yes (toggle right) {% endcomment -%}
        <input
          type="radio"
          id="{{ section_id }}-{{ option.position }}-premium-no{{ id_suffix }}"
          {% if visual_only %}name="{{ visual_name | escape }}"{% else %}name="{{ input_name | escape }}"{% endif %}
          value="{{ no_value | escape }}"
          {% unless visual_only %}form="{{ product_form_id }}"{% endunless %}
          data-product-url="{{ no_url }}"
          data-option-value-id="{{ no_id }}"
          class="premium-upgrade-toggle__input premium-upgrade-toggle__input--no"
          {% if checked_no %}checked{% endif %}
        >
        <label for="{{ section_id }}-{{ option.position }}-premium-no{{ id_suffix }}" class="premium-upgrade-toggle__label premium-upgrade-toggle__label--no">
          <span class="visually-hidden">{{ no_value }}</span>
        </label>
        <input
          type="radio"
          id="{{ section_id }}-{{ option.position }}-premium-yes{{ id_suffix }}"
          {% if visual_only %}name="{{ visual_name | escape }}"{% else %}name="{{ input_name | escape }}"{% endif %}
          value="{{ yes_value | escape }}"
          {% unless visual_only %}form="{{ product_form_id }}"{% endunless %}
          data-product-url="{{ yes_url }}"
          data-option-value-id="{{ yes_id }}"
          class="premium-upgrade-toggle__input premium-upgrade-toggle__input--yes"
          {% if checked_yes %}checked{% endif %}
        >
        <label for="{{ section_id }}-{{ option.position }}-premium-yes{{ id_suffix }}" class="premium-upgrade-toggle__label premium-upgrade-toggle__label--yes">
          <span class="visually-hidden">{{ yes_value }}</span>
        </label>
        <span class="premium-upgrade-toggle__slider" aria-hidden="true"></span>
      </span>
      {%- if upgrade_price != blank -%}
        <div class="premium-upgrade-card__cost"><span class="premium-upgrade-card__cost-price">{{ upgrade_price }}</span> <span class="premium-upgrade-card__cost-label">per tee</span></div>
      {%- endif -%}
    </fieldset>
  </div>
</div>
